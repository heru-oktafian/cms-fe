<section id="projects" class="bg-white pt-8">
  <div class="rounded-t-[48px] bg-orange-400 px-4 pb-20 sm:px-6 lg:px-8" style="padding-top: 5rem;">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <h2 class="inline-block text-3xl font-bold text-white transition-transform hover:scale-105">
          Projects <span class="text-blue-700">&amp; Portfolio</span>
        </h2>
        <p class="mt-2 text-white/85">Beberapa karya dan produk yang pernah saya bangun</p>
      </div>

      <% fallback_projects = [
        {
          "title" => "Project title placeholder",
          "summary" => "Summary dan stack badges project akan ditarik dari public projects endpoint pada fase berikutnya.",
          "thumbnail_path" => nil,
          "stack_items" => "Stack, Stack",
          "project_url" => nil,
          "repo_url" => nil
        },
        {
          "title" => "Project title placeholder",
          "summary" => "Summary dan stack badges project akan ditarik dari public projects endpoint pada fase berikutnya.",
          "thumbnail_path" => nil,
          "stack_items" => "Stack, Stack",
          "project_url" => nil,
          "repo_url" => nil
        }
      ] %>

      <% project_items = @projects.present? ? @projects : fallback_projects %>

      <div class="mt-12 space-y-10">
        <% project_items.each_with_index do |project, index| %>
          <% reverse_layout = index.odd? %>
          <% stack_items = project["stack_items"].to_s.split(",").map(&:strip).reject(&:blank?) %>
          <div class="group overflow-hidden rounded-2xl bg-white shadow-xl transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
            <div class="project-row flex flex-col <%= reverse_layout ? 'project-row-reverse' : 'project-row-normal' %>">
              <div class="overflow-hidden bg-gray-100 p-6 lg:w-1/2">
                <div class="flex h-[280px] w-full items-center justify-center rounded-lg bg-slate-100 lg:h-[320px]">
                  <% if project["thumbnail_path"].present? %>
                    <img src="<%= project["thumbnail_path"] %>" alt="<%= project["title"].presence || 'Project image' %>" class="max-h-full max-w-full rounded-lg object-contain object-center transition-transform duration-700 ease-in-out group-hover:scale-105">
                  <% else %>
                    <div class="flex h-full w-full items-center justify-center rounded-lg bg-slate-100 text-sm text-slate-400 transition-transform duration-700 ease-in-out group-hover:scale-105">
                      Project image <%= index + 1 %>
                    </div>
                  <% end %>
                </div>
              </div>

              <div class="flex flex-col justify-center p-8 lg:w-1/2">
                <h3 class="text-2xl font-bold text-blue-600 transition-colors duration-300 group-hover:text-orange-500"><%= project["title"].presence || 'Untitled project' %></h3>
                <p class="mt-4 text-sm font-semibold leading-7 text-slate-700"><%= project["summary"].presence || 'Belum ada ringkasan project.' %></p>

                <% if project["description"].present? %>
                  <p class="mt-3 text-sm leading-7 text-slate-500"><%= project["description"] %></p>
                <% end %>

                <% if stack_items.present? %>
                  <div class="mt-5 flex flex-wrap gap-2">
                    <% stack_items.each do |item| %>
                      <span class="cursor-pointer rounded-full bg-blue-100 px-3 py-1 text-xs font-bold text-blue-600 transition-colors hover:bg-blue-600 hover:text-white"><%= item %></span>
                    <% end %>
                  </div>
                <% end %>

                <% if project["project_url"].present? || project["repo_url"].present? %>
                  <div class="mt-6 flex flex-wrap gap-3">
                    <% if project["project_url"].present? %>
                      <a href="<%= project["project_url"] %>" target="_blank" rel="noopener noreferrer" class="rounded-full bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700">Live Preview</a>
                    <% end %>
                    <% if project["repo_url"].present? %>
                      <a href="<%= project["repo_url"] %>" target="_blank" rel="noopener noreferrer" class="rounded-full border border-blue-200 px-4 py-2 text-sm font-semibold text-blue-600 transition hover:border-blue-600 hover:bg-blue-50">Repository</a>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
