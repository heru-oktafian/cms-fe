<section id="tools" class="bg-white px-4 pt-28 pb-16 sm:px-6 lg:px-8" style="scroll-margin-top: 82px;">
  <div class="mx-auto mt-16 max-w-6xl fade-in text-center">
    <h2 class="inline-block text-3xl font-bold text-orange-500 transition-transform hover:scale-105">
      Tools <span class="text-blue-600">&amp; Technologies</span>
    </h2>
    <p class="mt-2 text-gray-600">Beberapa tools yang sering kami gunakan</p>

    <div class="mt-8">

    <% fallback_tools = [
      { "icon_text" => "🐹", "name" => "Golang", "url" => "" },
      { "icon_text" => "💎", "name" => "Ruby", "url" => "" },
      { "icon_text" => "⚛️", "name" => "React", "url" => "" },
      { "icon_text" => "🔷", "name" => "Flutter", "url" => "" },
      { "icon_text" => "🎨", "name" => "Figma", "url" => "" },
      { "icon_text" => "🐳", "name" => "Docker", "url" => "" }
    ] %>

    <% tool_items = @tools.present? ? @tools : fallback_tools %>

    <div class="tools-grid gap-4">
      <% tool_items.each do |tool| %>
        <% icon_text = tool["icon_text"].presence || "…" %>
        <% name = tool["name"].presence || "Tool" %>
        <% url = tool["url"].presence %>
        <% wrapper_classes = "card-hover block rounded-xl bg-white p-4 text-center shadow-sm" %>

        <% if url %>
          <a href="<%= url %>" target="_blank" rel="noopener noreferrer" class="<%= wrapper_classes %>">
            <div class="tool-emoji mb-2 text-3xl"><%= icon_text %></div>
            <span class="text-sm font-medium"><%= name %></span>
          </a>
        <% else %>
          <div class="<%= wrapper_classes %>">
            <div class="tool-emoji mb-2 text-3xl"><%= icon_text %></div>
            <span class="text-sm font-medium"><%= name %></span>
          </div>
        <% end %>
      <% end %>
    </div>
    </div>
  </div>
</section>
