<section id="contact" class="bg-sky-700 px-4 py-20 text-white sm:px-6 lg:px-8">
  <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-2">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-100/80">Contact</p>
      <h2 class="mt-4 text-3xl font-bold sm:text-4xl">Public contact section placeholder.</h2>
      <p class="mt-6 text-base leading-8 text-sky-100">Informasi kontak dari Profile dan Social Links akan ditampilkan di sini. Form ini nanti akan submit ke ContactMessage public endpoint.</p>
    </div>
    <div class="rounded-[32px] border border-white/15 bg-white/10 p-6 backdrop-blur-sm">
      <div class="grid gap-4">
        <input type="text" placeholder="Name" class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-sky-100/70">
        <input type="email" placeholder="Email" class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-sky-100/70">
        <input type="text" placeholder="Subject" class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-sky-100/70">
        <textarea rows="5" placeholder="Message" class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-sky-100/70"></textarea>
        <button type="button" class="rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-sky-700 transition hover:bg-orange-400 hover:text-white">Send Message</button>
      </div>
    </div>
  </div>
</section>
