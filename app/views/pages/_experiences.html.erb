<section id="experiences" class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Experiences</p>
    <h2 class="mt-4 text-3xl font-bold text-slate-950 sm:text-4xl">Perjalanan karir profesional-ku :</h2>

    <% fallback_experiences = [
      {
        "company" => "Company name",
        "position" => "Position title",
        "description" => "Pengalaman profesional akan tampil di sini setelah data endpoint terhubung.",
        "start_date" => nil,
        "end_date" => nil,
        "is_current" => false
      },
      {
        "company" => "Company name",
        "position" => "Position title",
        "description" => "Pengalaman profesional akan tampil di sini setelah data endpoint terhubung.",
        "start_date" => nil,
        "end_date" => nil,
        "is_current" => false
      }
    ] %>

    <% timeline_items = @experiences.present? ? @experiences : fallback_experiences %>

    <div class="mt-10 space-y-6 border-l-2 border-slate-200 pl-6">
      <% timeline_items.each do |experience| %>
        <% start_label = begin
             experience["start_date"].present? ? Date.parse(experience["start_date"]).strftime("%b %Y") : nil
           rescue StandardError
             experience["start_date"].presence
           end %>
        <% end_label = if experience["is_current"]
             "Sekarang"
           else
             begin
               experience["end_date"].present? ? Date.parse(experience["end_date"]).strftime("%b %Y") : nil
             rescue StandardError
               experience["end_date"].presence
             end
           end %>
        <% period_label = [start_label, end_label].compact.join(" - ") %>

        <div class="relative rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-md">
          <span class="absolute -left-[33px] top-8 h-4 w-4 rounded-full bg-sky-500"></span>
          <h3 class="text-lg font-semibold text-slate-900"><%= experience["position"].presence || "Position title" %></h3>
          <p class="mt-1 text-sm font-medium text-sky-600"><%= experience["company"].presence || "Company name" %></p>
          <% if period_label.present? %>
            <p class="mt-2 text-sm text-slate-500"><%= period_label %></p>
          <% end %>
          <p class="mt-4 text-sm leading-7 text-slate-600"><%= sanitize(experience["description"].presence || "Belum ada deskripsi pengalaman.", tags: %w[strong em br], attributes: []) %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
