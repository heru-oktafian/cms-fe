<section id="home" class="relative overflow-hidden bg-blue-600 px-4 pt-32 pb-20 text-white sm:px-6 lg:px-8 lg:pt-40 lg:pb-28">
  <div class="absolute top-0 right-0 h-full w-1/2 bg-orange-400" style="clip-path: polygon(25% 0, 100% 0, 100% 100%, 0% 100%);"></div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="flex flex-col-reverse items-center lg:flex-row">
      <div class="mt-10 pr-0 lg:w-1/2 lg:mt-0 lg:pr-10">
        <h1 class="mb-4 text-4xl font-bold leading-tight md:text-5xl">
          <%= (@profile["headline"].presence || "Dynamic Portfolio Website").html_safe %><br>
          <span class="text-orange-400" style="text-shadow: -1px 0 rgba(37,99,235,0.45), 0 1px rgba(37,99,235,0.45), 1px 0 rgba(37,99,235,0.45), 0 -1px rgba(37,99,235,0.45);"><%= @profile["sub_headline"].presence || "CMS Frontend" %></span>
        </h1>
        <div class="mb-8 max-w-lg text-lg text-blue-100 leading-8" style="text-shadow: 0 1px 2px rgba(15,23,42,0.25);">
          <%= sanitize((@profile["hero_description"].presence || "Fase pertama cms-fe sedang menyiapkan fondasi homepage publik yang nantinya akan terhubung penuh ke cms-be dan menyesuaikan visual portfolio lama."), tags: %w[strong em br], attributes: []) %>
        </div>
        <div class="flex gap-4">
          <a href="#projects" class="rounded-full bg-white px-6 py-3 font-semibold text-blue-600 transition-all duration-300 hover:bg-orange-500 hover:text-white hover:shadow-lg hover:scale-105 active:scale-95">Lihat Portfolio</a>
          <a href="#contact" class="rounded-full border-2 border-white px-6 py-3 font-semibold text-white transition-all duration-300 hover:bg-white hover:text-blue-600 hover:shadow-lg hover:scale-105 active:scale-95">Hubungi Saya</a>
        </div>
      </div>
      <div class="flex justify-center lg:w-1/2 lg:justify-end">
        <div class="group relative h-64 w-64 rounded-full bg-white/20 p-2 shadow-2xl backdrop-blur-sm transition-transform duration-500 ease-out hover:scale-105 md:h-80 md:w-80 lg:h-96 lg:w-96">
          <div class="flex h-full w-full items-center justify-center rounded-full border-4 border-white object-top text-center text-sm text-blue-100 transition-colors duration-500 group-hover:border-orange-400">
            <% if @profile["avatar_path"].present? %>
              <img src="<%= @profile["avatar_path"] %>" alt="<%= @profile["full_name"].presence || "Profile avatar" %>" class="h-full w-full rounded-full object-cover object-top">
            <% else %>
              Hero visual placeholder
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
